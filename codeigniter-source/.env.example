# ====================================================================
# DYNAMIC RAINBOW VIP PANEL PRO - STABLE ENVIRONMENT CONFIGURATION
# ====================================================================

# ENVIRONMENT MODE
# options: production, development, testing
# Use development for debugging database/routing issues, production for real-time hosting.
CI_ENVIRONMENT = production

# BASE SYSTEM DETAILS
# Set your actual domain name hosted on cPanel (including trailing slash)
# Keep empty or commented out to let CodeIgniter auto-detect the URL dynamically!
# app.baseURL = 'https://yourdomain.com/'
app.forceGlobalSecureRequests = false

# DATABASE CONNECTION CONFIG
# Hostname is almost always 'localhost' in cPanel environments
database.default.hostname = localhost
database.default.database = parallax_onecorepanel
database.default.username = parallax_onecorepanel
database.default.password = 'parallax_onecorepanel'
database.default.DBDriver = MySQLi
database.default.DBPrefix = ''

# JWT HANDSHAKE SIGNATURE SEALS
# Replace this with a strong random string (do not share this!)
# Used as the cryptographic core to verify keys against Game Guardian and Canary packet bypasses.
JWT_SECRET_KEY = "SUPER_SECURE_RAINBOW_NEON_SECRET_UUID_STRING"
JWT_EXPIRATION_TIME = 86400  # 24 Hours in seconds
